# AWS App Runner デプロイ用環境変数テンプレート
# 本番公開時は APP_USER / APP_PASSWORD / APP_SECRET_KEY を必ず設定してください

# ── アクセス制御 ──────────────────────────────────
APP_USER=your-email@example.com
APP_PASSWORD=change-me-strong-password
APP_SECRET_KEY=change-me-random-secret-string

# ── AWS ───────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── WordPress ─────────────────────────────────────
WP_URL=https://m.firekids.jp
WP_USER=
WP_APP_PASSWORD=

# ── S3（過去記事キャッシュ / 省略可）─────────────
S3_BUCKET=
